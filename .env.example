# Copy to `.env` (git-ignored) and fill in to use an API-backed LLM.
# Leave unset to use the default offline mock generator.

# Choose the generation backend without editing config.yaml:
#   mock (default) | claude | openai
LLM_PROVIDER=openai

# Only the key for your chosen provider is required.
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: HuggingFace token — only needed to pull the full MedQuAD dataset
# (data.use_huggingface: true) or to download gated/biomedical models.
# HF_TOKEN=hf_...
